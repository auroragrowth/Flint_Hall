{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/padel", "destination": "https://flint-hall-padel-production.up.railway.app/padel" },
    { "source": "/padel/:path*", "destination": "https://flint-hall-padel-production.up.railway.app/padel/:path*" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "X-Frame-Options",        "value": "DENY" },
        { "key": "Referrer-Policy",        "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",     "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/photos/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
